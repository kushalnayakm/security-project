{
  "info": {
    "name": "BiometricPlatform API — v1",
    "description": "Complete collection for testing the BiometricPlatform backend.\nBase URL: http://localhost:8000",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "user_id",  "value": "1" },
    { "key": "otp_code", "value": "" },
    { "key": "token",    "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health"
          }
        }
      ]
    },
    {
      "name": "Upload",
      "item": [
        {
          "name": "POST /api/upload/photo",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/upload/photo",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": "/path/to/your/selfie.jpg",
                  "description": "JPEG / PNG / WebP image"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "POST /api/users/register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/users/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Arjun Sharma\",\n  \"country_code\": \"+91\",\n  \"phone\": \"9876543210\",\n  \"photo_url\": \"uploads/selfies/example.jpg\"\n}"
            }
          }
        },
        {
          "name": "GET /api/users/profile/{id}",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/users/profile/{{user_id}}"
          }
        }
      ]
    },
    {
      "name": "OTP",
      "item": [
        {
          "name": "POST /api/otp/send",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.otp) { pm.collectionVariables.set('otp_code', json.otp); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/otp/send",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"country_code\": \"+91\",\n  \"phone\": \"9876543210\"\n}"
            }
          }
        },
        {
          "name": "POST /api/otp/verify",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) { pm.collectionVariables.set('token', json.access_token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/otp/verify",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"country_code\": \"+91\",\n  \"phone\": \"9876543210\",\n  \"otp\": \"{{otp_code}}\"\n}"
            }
          }
        }
      ]
    }
  ]
}
